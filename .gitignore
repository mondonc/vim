# Plugin directories (managed by vim-plug / lazy.nvim)
bundle/
autoload/plug.vim

# Undo history
undodir-vim/
undodir-nvim/

# Swap / backup (disabled but just in case)
*.swp
*.swo
*~

# AI flag (local only, created by ./install.sh ia)
.ai-enabled
.ai-model

# RAG flag (local only, created by ./install.sh rag)
.rag-enabled
.rag-embed-model

# Artefacts de build setuptools (quand pipx installe rag/ en éditable)
rag/*.egg-info/
rag/build/
rag/dist/
rag/__pycache__/
rag/*.pyc

# Cluster OAR (local only, created by ./install.sh cluster_oar)
.cluster-oar-enabled
.cluster_oar.conf
.cluster_oar_state
